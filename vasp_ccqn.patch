+        SUBROUTINE compute_e_ic(nions, nbonds, bonds, pos, forces, e3)
+          INTEGER, INTENT(IN)  :: nions, nbonds
+          INTEGER, INTENT(IN)  :: bonds(2, nbonds)
+          REAL(q), INTENT(IN)  :: pos(3, nions)
+          REAL(q), INTENT(IN)  :: forces(3, nions)
+          REAL(q), INTENT(OUT) :: e3(3, nions)
+
+          INTEGER :: k, ii, jj
+          REAL(q) :: v_ij(3), v_norm2, proj_j, proj_i, p_ij(3), p_norm
+
+          e3 = 0._q
+
+          DO k = 1, nbonds
+            ii = bonds(1, k)
+            jj = bonds(2, k)
+
+            v_ij = pos(:, jj) - pos(:, ii)
+            v_norm2 = SUM(v_ij * v_ij)
+            IF (v_norm2 < 1E-12_q) CYCLE
+
+            proj_j = SUM(v_ij * forces(:, jj)) / v_norm2
+            proj_i = SUM(v_ij * forces(:, ii)) / v_norm2
+
+            p_ij = v_ij * (proj_j - proj_i)
+            p_norm = SQRT(SUM(p_ij * p_ij))
+            IF (p_norm < 1E-12_q) CYCLE
+
+            p_ij = p_ij / p_norm
+            e3(:, ii) = e3(:, ii) + p_ij
+            e3(:, jj) = e3(:, jj) - p_ij
+          END DO
+        END SUBROUTINE compute_e_ic
+

+#include "symbol.inc"
+!***********************************************************************
+!
+!  CCQN-TS: Cone-shaped Constrained Quasi-Newton transition state optimizer
+!
+!  - Reads parameters and a fixed ascent direction from ccqn.ts.
+!  - Uses a cone-constrained step in the positive definite region ("well").
+!  - Switches to PRFO (trust-radius) once the approximate Hessian becomes indefinite.
+!
+!***********************************************************************
+
+      MODULE ccqn_ts
+        USE prec
+        USE constant
+        USE lattice
+        USE ini
+        USE poscar
+        USE base
+        USE string, ONLY: str
+        USE tutor, ONLY: vtutor
+        IMPLICIT NONE
+        PRIVATE
+
+        PUBLIC :: ccqn_ts_opt
+
+        REAL(q), PARAMETER :: CCQN_EPSR = 1E-12_q
+        INTEGER, PARAMETER :: CCQN_MAX_BONDS = 10000
+
+        TYPE ccqn_input
+          REAL(q) :: init_hessian_scale
+          REAL(q) :: delta_well
+          REAL(q) :: cos_phi
+          REAL(q) :: neg_eig_tol
+          REAL(q) :: delta_min
+          REAL(q) :: delta_max
+          REAL(q) :: rho_inc
+          REAL(q) :: rho_dec
+          REAL(q) :: sigma_inc
+          REAL(q) :: sigma_dec
+          REAL(q) :: prfo_a_init
+          INTEGER :: prfo_max_iter
+          INTEGER :: verbose
+          INTEGER :: nbonds = 0
+          INTEGER, ALLOCATABLE :: bonds(:,:)   ! bonds(2, nbonds), 1-based
+          LOGICAL :: sparse_vec = .FALSE.
+          INTEGER :: nvec_specified = 0
+        END TYPE
+
+        TYPE ccqn_state
+          LOGICAL :: initialized = .FALSE.
+          INTEGER :: n = 0
+          INTEGER :: nions = 0
+          INTEGER :: iter = 0
+          REAL(q) :: delta = 0._q
+          REAL(q) :: f_prev = 0._q
+          INTEGER :: iu_log = 0
+          LOGICAL :: log_open = .FALSE.
+          REAL(q), ALLOCATABLE :: b(:,:)        ! Hessian approximation (Cartesian)
+          REAL(q), ALLOCATABLE :: x_prev(:)     ! Previous positions (Cartesian)
+          REAL(q), ALLOCATABLE :: g_prev(:)     ! Previous gradient (Cartesian)
+          REAL(q), ALLOCATABLE :: s_prev(:)     ! Previous step (Cartesian)
+          REAL(q), ALLOCATABLE :: e(:)          ! Ascent direction (Cartesian, unit)
+          REAL(q) :: ratio_last = 0._q
+          LOGICAL :: have_ratio = .FALSE.
+          REAL(q) :: pred_last = 0._q
+          REAL(q) :: dE_last = 0._q
+          LOGICAL :: use_bonds = .FALSE.
+        END TYPE
+
+        TYPE(ccqn_input), SAVE :: Inp
+        TYPE(ccqn_state), SAVE :: St
+
+      CONTAINS
+
+        SUBROUTINE ccqn_ts_opt(DYN, T_INFO, INFO, LATT_CUR, IO, EPOT, FACT, LSTOP2)
+          TYPE(dynamics) :: DYN
+          TYPE(type_info) :: T_INFO
+          TYPE(info_struct) INFO
+          TYPE(latt) :: LATT_CUR
+          TYPE(in_struct) :: IO
+          REAL(q) :: EPOT
+          REAL(q) :: FACT
+          LOGICAL :: LSTOP2
+
+          INTEGER :: i, j, n, nions
+          REAL(q), ALLOCATABLE :: pos_cart(:,:), forces(:,:), x(:), g(:), y(:), s(:)
+          REAL(q), ALLOCATABLE :: e3(:,:)
+          REAL(q) :: fmax, step_norm, cos_es, min_eig, norm_e
+          INTEGER :: neg_count
+          LOGICAL :: in_well, found_bonds
+
+          IF (DYN%ISIF>2) THEN
+            CALL vtutor%error("ERROR: CCQN-TS supports only atomic relaxation (set ISIF <= 2).")
+          END IF
+
+          IF (FACT==0._q) THEN
+            CALL vtutor%error("ERROR: CCQN-TS internal scaling FACT is zero (unsupported setup).")
+          END IF
+
+          nions = T_INFO%NIONS
+          n = 3*nions
+
+          ALLOCATE(pos_cart(3,nions), forces(3,nions), x(n), g(n), y(n), s(n))
+
+          forces = DYN%D2C / FACT
+          pos_cart = DYN%POSION
+          CALL DIRKAR(nions, pos_cart, LATT_CUR%A)
+          CALL pack3(nions, pos_cart, x)
+          CALL pack3(nions, -forces, g)
+          CALL apply_selective_mask(T_INFO, g)
+
+          ! Convergence criterion should ignore frozen degrees of freedom (Selective dynamics).
+          fmax = 0._q
+          DO i=1,nions
+            fmax = MAX(fmax, SQRT(g(3*(i-1)+1)**2 + g(3*(i-1)+2)**2 + g(3*(i-1)+3)**2))
+          END DO
+
+          IF (.NOT. St%initialized) THEN
+            ALLOCATE(e3(3,nions))
+            CALL ccqn_read_input(IO%IU6, nions, e3, found_bonds)
+            IF (found_bonds) THEN
+              CALL compute_e_ic(nions, Inp%nbonds, Inp%bonds, pos_cart, forces, e3)
+            END IF
+            CALL ccqn_init_state(T_INFO, e3, IO%IU6, found_bonds)
+            DEALLOCATE(e3)
+            CALL ccqn_open_log(IO%IU6)
+            IF (St%log_open) CALL ccqn_log_header(St%iu_log)
+            St%f_prev = EPOT
+            St%x_prev = x
+            St%g_prev = g
+            St%s_prev = 0._q
+            St%iter = 0
+            St%have_ratio = .FALSE.
+          ELSE
+            IF (St%nions /= nions) THEN
+              CALL vtutor%error("ERROR: CCQN-TS internal state mismatch (NIONS changed).")
+            END IF
+
+            y = g - St%g_prev
+            ! NOTE: ratio/prediction must be computed with the Hessian used to generate the previous step
+            ! (i.e., before the quasi-Newton update with (s_prev, y)).
+            CALL ccqn_update_ratio_and_delta(St%n, St%b, St%g_prev, St%s_prev, EPOT - St%f_prev)
+            CALL ts_bfgs_update(St%n, St%b, St%s_prev, y)
+
+            St%f_prev = EPOT
+            St%x_prev = x
+            St%g_prev = g
+          END IF
+
+          St%iter = St%iter + 1
+
+          ! Recompute direction vector each step in BONDS mode
+          IF (St%use_bonds) THEN
+            ALLOCATE(e3(3,nions))
+            CALL compute_e_ic(nions, Inp%nbonds, Inp%bonds, pos_cart, forces, e3)
+            CALL pack3(nions, e3, St%e)
+            CALL apply_selective_mask(T_INFO, St%e)
+            norm_e = SQRT(SUM(St%e*St%e))
+            IF (norm_e < 1E-12_q) THEN
+              IF (IO%IU6>=0) WRITE(IO%IU6,'(3X,A)') &
+                'CCQN-TS: WARNING: IC direction is zero, keeping previous direction.'
+            ELSE
+              St%e = St%e / norm_e
+            END IF
+            DEALLOCATE(e3)
+          END IF
+
+          CALL ccqn_hessian_diagnostics(St%n, St%b, Inp%neg_eig_tol, neg_count, min_eig, in_well)
+
+          IF (DYN%EDIFFG < 0._q) THEN
+            LSTOP2 = (fmax <= ABS(DYN%EDIFFG)) .AND. (neg_count == 1)
+            IF (LSTOP2) THEN
+              INFO%LSTOP = .TRUE.
+              DYN%POSIOC = DYN%POSION
+              IF (IO%IU6>=0) CALL ccqn_write_status(IO%IU6, St%iter, EPOT, fmax, neg_count, min_eig, "CONVERGED", 0._q, 0._q, 0._q)
+              IF (St%log_open) CALL ccqn_log_line(St%iu_log, St%iter, EPOT, fmax, neg_count, min_eig, "CONVERGED", St%delta, 0._q, 0._q, St%have_ratio, St%ratio_last, St%pred_last, St%dE_last)
+              DEALLOCATE(pos_cart, forces, x, g, y, s)
+              RETURN
+            END IF
+          END IF
+
+          IF (in_well) THEN
+            s = solve_cone_step_alm(St%n, g, St%b, St%e, Inp%delta_well, Inp%cos_phi)
+          ELSE
+            s = prfo_step(St%n, g, St%b, St%delta, 1, Inp%prfo_a_init, Inp%prfo_max_iter)
+          END IF
+          CALL apply_selective_mask(T_INFO, s)
+
+          step_norm = SQRT(SUM(s*s))
+          cos_es = 0._q
+          IF (step_norm > 0._q) cos_es = SUM(St%e*s) / step_norm
+
+          IF (Inp%verbose>0 .AND. IO%IU6>=0) THEN
+            IF (in_well) THEN
+              CALL ccqn_write_status(IO%IU6, St%iter, EPOT, fmax, neg_count, min_eig, "WELL", St%delta, step_norm, cos_es)
+            ELSE
+              CALL ccqn_write_status(IO%IU6, St%iter, EPOT, fmax, neg_count, min_eig, "PRFO", St%delta, step_norm, cos_es)
+            END IF
+            IF (St%have_ratio) THEN
+              WRITE(IO%IU6,'(3X,A,1X,F10.4)') 'CCQN-TS ratio(pred/act)=', St%ratio_last
+            END IF
+          END IF
+          IF (St%log_open) THEN
+            IF (in_well) THEN
+              CALL ccqn_log_line(St%iu_log, St%iter, EPOT, fmax, neg_count, min_eig, "WELL", St%delta, step_norm, cos_es, St%have_ratio, St%ratio_last, St%pred_last, St%dE_last)
+            ELSE
+              CALL ccqn_log_line(St%iu_log, St%iter, EPOT, fmax, neg_count, min_eig, "PRFO", St%delta, step_norm, cos_es, St%have_ratio, St%ratio_last, St%pred_last, St%dE_last)
+            END IF
+          END IF
+
+          DYN%POSIOC = DYN%POSION
+
+          CALL unpack3(nions, x + s, pos_cart)
+          CALL KARDIR(nions, pos_cart, LATT_CUR%B)
+          DYN%POSION = pos_cart
+
+          St%s_prev = s
+
+          DEALLOCATE(pos_cart, forces, x, g, y, s)
+
+        END SUBROUTINE ccqn_ts_opt
+
+
+        SUBROUTINE ccqn_init_state(T_INFO, e3, IU6, use_bonds)
+          TYPE(type_info) :: T_INFO
+          REAL(q), INTENT(IN) :: e3(3,T_INFO%NIONS)
+          INTEGER, INTENT(IN) :: IU6
+          LOGICAL, INTENT(IN) :: use_bonds
+
+          INTEGER :: i
+          REAL(q) :: norm_e
+
+          St%use_bonds = use_bonds
+          St%nions = T_INFO%NIONS
+          St%n = 3*St%nions
+          IF (.NOT. ALLOCATED(St%b)) ALLOCATE(St%b(St%n,St%n))
+          IF (.NOT. ALLOCATED(St%x_prev)) ALLOCATE(St%x_prev(St%n))
+          IF (.NOT. ALLOCATED(St%g_prev)) ALLOCATE(St%g_prev(St%n))
+          IF (.NOT. ALLOCATED(St%s_prev)) ALLOCATE(St%s_prev(St%n))
+          IF (.NOT. ALLOCATED(St%e)) ALLOCATE(St%e(St%n))
+
+          St%b = 0._q
+          DO i=1,St%n
+            St%b(i,i) = Inp%init_hessian_scale
+          END DO
+
+          St%delta = Inp%delta_well
+
+          CALL pack3(St%nions, e3, St%e)
+          CALL apply_selective_mask(T_INFO, St%e)
+          norm_e = SQRT(SUM(St%e*St%e))
+          IF (norm_e < 1E-12_q) THEN
+            CALL vtutor%error("ERROR: CCQN-TS: ccqn.ts direction is zero after masking.")
+          END IF
+          St%e = St%e / norm_e
+
+          St%initialized = .TRUE.
+          IF (IU6>=0 .AND. Inp%verbose>0) CALL ccqn_write_input_summary(IU6)
+        END SUBROUTINE ccqn_init_state
+
+
+        SUBROUTINE ccqn_set_defaults()
+          Inp%init_hessian_scale = 70._q
+          Inp%delta_well = 0.1_q
+          Inp%cos_phi = 0.1_q
+          Inp%neg_eig_tol = 1E-8_q
+          Inp%delta_min = 0.02_q
+          Inp%delta_max = 0.3_q
+          Inp%rho_inc = 1.2_q
+          Inp%rho_dec = 2._q
+          Inp%sigma_inc = 1.2_q
+          Inp%sigma_dec = 0.5_q
+          Inp%prfo_a_init = 1._q
+          Inp%prfo_max_iter = 50
+          Inp%verbose = 1
+        END SUBROUTINE ccqn_set_defaults
+
+
+        SUBROUTINE ccqn_validate_input()
+          Inp%init_hessian_scale = MAX(Inp%init_hessian_scale, 1E-6_q)
+          Inp%delta_well = MAX(Inp%delta_well, 1E-6_q)
+          Inp%cos_phi = MIN(1._q, MAX(-1._q, Inp%cos_phi))
+          Inp%neg_eig_tol = MAX(Inp%neg_eig_tol, 0._q)
+          Inp%delta_min = MAX(Inp%delta_min, 1E-6_q)
+          Inp%delta_max = MAX(Inp%delta_max, Inp%delta_min)
+          Inp%rho_inc = MAX(Inp%rho_inc, 1._q)
+          Inp%rho_dec = MAX(Inp%rho_dec, 1._q)
+          Inp%sigma_inc = MAX(Inp%sigma_inc, 1._q)
+          Inp%sigma_dec = MIN(1._q, MAX(1E-6_q, Inp%sigma_dec))
+          Inp%prfo_a_init = MAX(Inp%prfo_a_init, 1E-6_q)
+          Inp%prfo_max_iter = MAX(1, Inp%prfo_max_iter)
+        END SUBROUTINE ccqn_validate_input
+
+
+        SUBROUTINE ccqn_replace_equals(line)
+          CHARACTER(LEN=*), INTENT(INOUT) :: line
+          INTEGER :: i
+          DO i=1,LEN(line)
+            IF (line(i:i) == '=') line(i:i) = ' '
+          END DO
+        END SUBROUTINE ccqn_replace_equals
+
+
+        SUBROUTINE ccqn_read_input(IU6, nions, e3, found_bonds)
+          INTEGER, INTENT(IN) :: IU6, nions
+          REAL(q), INTENT(OUT) :: e3(3,nions)
+          LOGICAL, INTENT(OUT) :: found_bonds
+
+          INTEGER :: iu, ierr, ios, count, p1, p2, pc, k
+          INTEGER :: nbonds_read, bi, bj
+          INTEGER :: bond_buf(2, CCQN_MAX_BONDS)
+          INTEGER :: vec_idx
+          LOGICAL :: in_vec, in_bonds, sparse_vec, vec_format_known
+          CHARACTER(LEN=512) :: line, uline
+          CHARACTER(LEN=64) :: key
+          REAL(q) :: val, a, b, c
+
+          CALL ccqn_set_defaults()
+          e3 = 0._q
+          in_vec = .FALSE.
+          in_bonds = .FALSE.
+          found_bonds = .FALSE.
+          sparse_vec = .FALSE.
+          vec_format_known = .FALSE.
+          count = 0
+          nbonds_read = 0
+
+          OPEN(NEWUNIT=iu, FILE='ccqn.ts', STATUS='OLD', ACTION='READ', IOSTAT=ierr)
+          IF (ierr /= 0) THEN
+            CALL vtutor%error("ERROR: CCQN-TS: could not open ccqn.ts (required input file).")
+          END IF
+
+          DO
+            READ(iu,'(A)',IOSTAT=ierr) line
+            IF (ierr /= 0) EXIT
+
+            pc = 0
+            p1 = INDEX(line,'!')
+            p2 = INDEX(line,'#')
+            IF (p1>0 .AND. p2>0) pc = MIN(p1,p2)
+            IF (p1>0 .AND. p2==0) pc = p1
+            IF (p2>0 .AND. p1==0) pc = p2
+            IF (pc>0) line = line(:pc-1)
+            line = ADJUSTL(line)
+            IF (LEN_TRIM(line) == 0) CYCLE
+
+            uline = ccqn_uppercase(line)
+
+            ! --- BONDS block: read pairs of atom indices ---
+            IF (in_bonds) THEN
+              bi = 0; bj = 0
+              READ(uline,*,IOSTAT=ios) bi, bj
+              IF (ios == 0 .AND. bi >= 1 .AND. bj >= 1) THEN
+                nbonds_read = nbonds_read + 1
+                IF (nbonds_read > CCQN_MAX_BONDS) THEN
+                  CALL vtutor%error("ERROR: CCQN-TS: too many bonds in ccqn.ts.")
+                END IF
+                bond_buf(1, nbonds_read) = bi
+                bond_buf(2, nbonds_read) = bj
+                CYCLE
+              ELSE
+                in_bonds = .FALSE.
+                ! Fall through to key-value parsing below
+              END IF
+            END IF
+
+            ! --- VECTOR block: dense (3 values) or sparse (idx + 3 values) ---
+            IF (in_vec) THEN
+              IF (sparse_vec) THEN
+                ! Confirmed sparse mode: read atom_index vx vy vz
+                vec_idx = 0; a = 0._q; b = 0._q; c = 0._q
+                READ(uline,*,IOSTAT=ios) vec_idx, a, b, c
+                IF (ios == 0 .AND. vec_idx >= 1) THEN
+                  count = count + 1
+                  IF (vec_idx < 1 .OR. vec_idx > nions) THEN
+                    CALL vtutor%error("ERROR: CCQN-TS: VECTOR atom index " // str(vec_idx) // &
+                                      " out of range [1," // str(nions) // "].")
+                  END IF
+                  e3(1,vec_idx) = a; e3(2,vec_idx) = b; e3(3,vec_idx) = c
+                  CYCLE
+                ELSE
+                  in_vec = .FALSE.
+                  ! Fall through to key-value parsing
+                END IF
+              ELSE IF (vec_format_known) THEN
+                ! Confirmed dense mode (backward compatible)
+                a = 0._q; b = 0._q; c = 0._q
+                READ(uline,*,IOSTAT=ios) a, b, c
+                IF (ios == 0) THEN
+                  count = count + 1
+                  IF (count <= nions) THEN
+                    e3(1,count) = a; e3(2,count) = b; e3(3,count) = c
+                  END IF
+                  IF (count >= nions) EXIT
+                END IF
+                CYCLE
+              ELSE
+                ! Format unknown: auto-detect from first data line
+                vec_idx = 0; a = 0._q; b = 0._q; c = 0._q
+                READ(uline,*,IOSTAT=ios) vec_idx, a, b, c
+                IF (ios == 0 .AND. vec_idx >= 1) THEN
+                  ! 4 values parsed -> sparse mode
+                  sparse_vec = .TRUE.; vec_format_known = .TRUE.
+                  count = count + 1
+                  IF (vec_idx < 1 .OR. vec_idx > nions) THEN
+                    CALL vtutor%error("ERROR: CCQN-TS: VECTOR atom index " // str(vec_idx) // &
+                                      " out of range [1," // str(nions) // "].")
+                  END IF
+                  e3(1,vec_idx) = a; e3(2,vec_idx) = b; e3(3,vec_idx) = c
+                  CYCLE
+                ELSE
+                  ! 4 values failed -> dense mode
+                  sparse_vec = .FALSE.; vec_format_known = .TRUE.
+                  a = 0._q; b = 0._q; c = 0._q
+                  READ(uline,*,IOSTAT=ios) a, b, c
+                  IF (ios == 0) THEN
+                    count = count + 1
+                    IF (count <= nions) THEN
+                      e3(1,count) = a; e3(2,count) = b; e3(3,count) = c
+                    END IF
+                    IF (count >= nions) EXIT
+                  END IF
+                  CYCLE
+                END IF
+              END IF
+            END IF
+
+            ! --- Key-value / keyword parsing ---
+            CALL ccqn_replace_equals(uline)
+
+            key = ''
+            READ(uline,*,IOSTAT=ios) key
+            IF (ios /= 0) CYCLE
+            key = TRIM(key)
+
+            IF (key == 'VECTOR' .OR. key == 'MODE' .OR. key == 'DIRECTION') THEN
+              IF (nbonds_read > 0) THEN
+                CALL vtutor%error("ERROR: CCQN-TS: ccqn.ts has both BONDS and VECTOR blocks.")
+              END IF
+              in_vec = .TRUE.
+              CYCLE
+            END IF
+
+            IF (key == 'BONDS') THEN
+              IF (in_vec .OR. count > 0) THEN
+                CALL vtutor%error("ERROR: CCQN-TS: ccqn.ts has both BONDS and VECTOR blocks.")
+              END IF
+              in_bonds = .TRUE.
+              CYCLE
+            END IF
+
+            val = 0._q
+            READ(uline,*,IOSTAT=ios) key, val
+            IF (ios /= 0) CYCLE
+
+            SELECT CASE (TRIM(key))
+              CASE('INIT_HESS_SCALE','INIT_HESSIAN_SCALE','HESS_SCALE')
+                Inp%init_hessian_scale = val
+              CASE('DELTA_WELL','DELTAWELL')
+                Inp%delta_well = val
+              CASE('COSPHI','COS_PHI')
+                Inp%cos_phi = val
+              CASE('NEG_EIG_TOL','NEG_EIGEN_TOL','NEG_EIG_THR')
+                Inp%neg_eig_tol = val
+              CASE('DELTA_MIN')
+                Inp%delta_min = val
+              CASE('DELTA_MAX')
+                Inp%delta_max = val
+              CASE('RHO_INC')
+                Inp%rho_inc = val
+              CASE('RHO_DEC')
+                Inp%rho_dec = val
+              CASE('SIGMA_INC')
+                Inp%sigma_inc = val
+              CASE('SIGMA_DEC')
+                Inp%sigma_dec = val
+              CASE('PRFO_A_INIT','A_INIT')
+                Inp%prfo_a_init = val
+              CASE('PRFO_MAX_ITER','MAX_ITER')
+                Inp%prfo_max_iter = INT(val)
+              CASE('VERBOSE')
+                Inp%verbose = INT(val)
+              CASE DEFAULT
+                IF (IU6>=0) WRITE(IU6,'(3X,A,A)') 'CCQN-TS: WARNING: unknown key in ccqn.ts: ', TRIM(key)
+            END SELECT
+          END DO
+
+          CLOSE(iu)
+          CALL ccqn_validate_input()
+
+          ! --- Post-processing: validate BONDS or VECTOR ---
+          IF (nbonds_read > 0) THEN
+            found_bonds = .TRUE.
+            Inp%nbonds = nbonds_read
+            IF (ALLOCATED(Inp%bonds)) DEALLOCATE(Inp%bonds)
+            ALLOCATE(Inp%bonds(2, nbonds_read))
+            Inp%bonds(:, 1:nbonds_read) = bond_buf(:, 1:nbonds_read)
+            DO k = 1, nbonds_read
+              IF (Inp%bonds(1,k) < 1 .OR. Inp%bonds(1,k) > nions .OR. &
+                  Inp%bonds(2,k) < 1 .OR. Inp%bonds(2,k) > nions) THEN
+                CALL vtutor%error("ERROR: CCQN-TS: bond index out of range [1," // str(nions) // "] in ccqn.ts.")
+              END IF
+              IF (Inp%bonds(1,k) == Inp%bonds(2,k)) THEN
+                CALL vtutor%error("ERROR: CCQN-TS: bond with identical atom indices in ccqn.ts.")
+              END IF
+            END DO
+          ELSE IF (sparse_vec) THEN
+            IF (count == 0) THEN
+              CALL vtutor%error("ERROR: CCQN-TS: VECTOR block has no entries.")
+            END IF
+            Inp%sparse_vec = .TRUE.
+            Inp%nvec_specified = count
+          ELSE IF (count < nions) THEN
+            CALL vtutor%error("ERROR: CCQN-TS: ccqn.ts requires either a VECTOR block " // &
+                              "(NIONS lines of 3 numbers, or sparse: idx vx vy vz) or a BONDS block.")
+          END IF
+        END SUBROUTINE ccqn_read_input
+
+
+        SUBROUTINE ccqn_write_input_summary(IU6)
+          INTEGER, INTENT(IN) :: IU6
+          INTEGER :: k
+          IF (IU6 < 0) RETURN
+          WRITE(IU6,'(/,3X,A)') 'CCQN-TS input (from ccqn.ts):'
+          IF (St%use_bonds) THEN

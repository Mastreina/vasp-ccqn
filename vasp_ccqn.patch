+        SUBROUTINE ccqn_update_ratio_and_delta(n, b, g_prev, s_prev, denom)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: b(n,n)
+          REAL(q), INTENT(IN) :: g_prev(n), s_prev(n)
+          REAL(q), INTENT(IN) :: denom
+          REAL(q), ALLOCATABLE :: bs(:)
+          REAL(q) :: pred, ratio
+          INTEGER :: neg_count
+          REAL(q) :: min_eig
+          LOGICAL :: in_well
+
+          IF (SUM(ABS(s_prev)) < 1E-14_q) RETURN
+
+          ALLOCATE(bs(n))
+          bs = MATMUL(b, s_prev)
+          pred = SUM(g_prev*s_prev) + 0.5_q*SUM(s_prev*bs)
+          DEALLOCATE(bs)
+
+          St%pred_last = pred
+          St%dE_last = denom
+
+          ratio = 0._q
+          IF (denom /= 0._q) ratio = pred / denom
+          St%ratio_last = ratio
+          St%have_ratio = .TRUE.
+
+          CALL ccqn_hessian_diagnostics(n, b, Inp%neg_eig_tol, neg_count, min_eig, in_well)
+          IF (.NOT. in_well) THEN
+            St%delta = trust_radius_update(St%delta, ratio, Inp%rho_inc, Inp%rho_dec, Inp%sigma_inc, Inp%sigma_dec, Inp%delta_min, Inp%delta_max)
+          END IF
+        END SUBROUTINE ccqn_update_ratio_and_delta
+
+
+        REAL(q) FUNCTION trust_radius_update(delta, ratio, rho_inc, rho_dec, sigma_inc, sigma_dec, delta_min, delta_max)
+          REAL(q), INTENT(IN) :: delta, ratio, rho_inc, rho_dec, sigma_inc, sigma_dec, delta_min, delta_max
+          REAL(q) :: d
+          d = delta
+          IF (ratio == 0._q) THEN
+            trust_radius_update = MAX(delta_min, d*sigma_dec)
+            RETURN
+          END IF
+          IF (ratio >= 1._q/rho_inc .AND. ratio <= rho_inc) THEN
+            trust_radius_update = MIN(delta_max, d*sigma_inc)
+            RETURN
+          END IF
+          IF (ratio <= 1._q/rho_dec .OR. ratio >= rho_dec) THEN
+            trust_radius_update = MAX(delta_min, d*sigma_dec)
+            RETURN
+          END IF
+          trust_radius_update = d
+        END FUNCTION trust_radius_update
+
+
+        SUBROUTINE ccqn_hessian_diagnostics(n, b, tol, neg_count, min_eig, in_well)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: b(n,n)
+          REAL(q), INTENT(IN) :: tol
+          INTEGER, INTENT(OUT) :: neg_count
+          REAL(q), INTENT(OUT) :: min_eig
+          LOGICAL, INTENT(OUT) :: in_well
+
+          REAL(q), ALLOCATABLE :: a(:,:), w(:)
+          INTEGER :: i
+
+          ALLOCATE(a(n,n), w(n))
+          a = 0.5_q*(b + TRANSPOSE(b))
+          CALL dsyev_wrap('N', n, a, w)
+          min_eig = w(1)
+          neg_count = 0
+          DO i=1,n
+            IF (w(i) < -tol) neg_count = neg_count + 1
+          END DO
+          in_well = (min_eig > tol)
+          DEALLOCATE(a, w)
+        END SUBROUTINE ccqn_hessian_diagnostics
+
+
+        SUBROUTINE dsyev_wrap(jobz, n, a, w)
+          CHARACTER(LEN=1), INTENT(IN) :: jobz
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(INOUT) :: a(n,n)
+          REAL(q), INTENT(OUT) :: w(n)
+
+          INTEGER :: info, lwork
+          REAL(q), ALLOCATABLE :: work(:)
+          REAL(q) :: workq(1)
+
+          lwork = -1
+          CALL DSYEV(jobz, 'U', n, a, n, w, workq, lwork, info)
+          IF (info /= 0) CALL vtutor%bug("CCQN-TS: DSYEV query failed. INFO=" // str(info), __FILE__, __LINE__)
+          lwork = MAX(1, INT(workq(1)))
+          ALLOCATE(work(lwork))
+          CALL DSYEV(jobz, 'U', n, a, n, w, work, lwork, info)
+          DEALLOCATE(work)
+          IF (info /= 0) CALL vtutor%bug("CCQN-TS: DSYEV failed. INFO=" // str(info), __FILE__, __LINE__)
+        END SUBROUTINE dsyev_wrap
+
+
+        SUBROUTINE ts_bfgs_update(n, b, s, y)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(INOUT) :: b(n,n)
+          REAL(q), INTENT(IN) :: s(n), y(n)
+
+          REAL(q), PARAMETER :: eps = 1E-12_q
+          REAL(q) :: sy, c, denom, js
+          REAL(q), ALLOCATABLE :: a(:,:), w(:), qts(:), tmp(:), tbs(:), bs(:), jv(:), u(:)
+          INTEGER :: i
+
+          IF (SUM(ABS(s)) < eps) RETURN
+
+          b = 0.5_q*(b + TRANSPOSE(b))
+
+          sy = SUM(s*y)
+          IF (ABS(sy) < eps) RETURN
+
+          ALLOCATE(a(n,n), w(n), qts(n), tmp(n), tbs(n), bs(n), jv(n), u(n))
+          a = b
+          CALL dsyev_wrap('V', n, a, w)     ! a becomes eigenvectors, w eigenvalues (ascending)
+
+          qts = MATMUL(TRANSPOSE(a), s)
+          DO i=1,n
+            tmp(i) = ABS(w(i)) * qts(i)
+          END DO
+          tbs = MATMUL(a, tmp)
+          c = SUM(s*tbs)
+
+          denom = sy*sy + c*c
+          IF (ABS(denom) < eps) THEN
+            DEALLOCATE(a, w, qts, tmp, tbs, bs, jv, u)
+            RETURN
+          END IF
+
+          u = (y*sy + c*tbs) / denom
+
+          bs = MATMUL(b, s)
+          jv = y - bs
+          js = SUM(jv*s)
+
+          DO i=1,n
+            b(:,i) = b(:,i) + jv*u(i) + u*jv(i) - js*u*u(i)
+          END DO
+          b = 0.5_q*(b + TRANSPOSE(b))
+
+          DEALLOCATE(a, w, qts, tmp, tbs, bs, jv, u)
+        END SUBROUTINE ts_bfgs_update
+
+
+        FUNCTION prfo_step(n, g, b, delta, mu, a_init, max_iter) RESULT(s)
+          INTEGER, INTENT(IN) :: n, mu, max_iter
+          REAL(q), INTENT(IN) :: g(n), b(n,n), delta, a_init
+          REAL(q) :: s(n)
+
+          REAL(q) :: a_low, a_high, a_mid
+          REAL(q) :: norm_s, norm_high, norm_mid
+          INTEGER :: it
+          REAL(q) :: s_high(n), s_mid(n)
+
+          s = prfo_step_with_a(n, g, b, a_init, mu)
+          norm_s = SQRT(SUM(s*s))
+          IF (delta <= 0._q .OR. norm_s <= delta + 1E-10_q) RETURN
+
+          a_low = 1E-6_q
+          a_high = a_init
+          s_high = s
+          norm_high = norm_s
+          DO WHILE (norm_high < delta .AND. a_high < 1E6_q)
+            a_high = 2._q*a_high
+            s_high = prfo_step_with_a(n, g, b, a_high, mu)
+            norm_high = SQRT(SUM(s_high*s_high))
+          END DO
+          IF (norm_high < delta) THEN
+            s = s_high
+            RETURN
+          END IF
+
+          DO it=1,max_iter
+            a_mid = 0.5_q*(a_low + a_high)
+            s_mid = prfo_step_with_a(n, g, b, a_mid, mu)
+            norm_mid = SQRT(SUM(s_mid*s_mid))
+            IF (ABS(norm_mid - delta) < 1E-10_q) THEN
+              s = s_mid
+              RETURN
+            END IF
+            IF (norm_mid < delta) THEN
+              a_low = a_mid
+            ELSE
+              a_high = a_mid
+            END IF
+          END DO
+
+          s = prfo_step_with_a(n, g, b, a_high, mu)
+        END FUNCTION prfo_step
+
+
+        FUNCTION prfo_step_with_a(n, g, b, a_scale, mu) RESULT(s)
+          INTEGER, INTENT(IN) :: n, mu
+          REAL(q), INTENT(IN) :: g(n), b(n,n), a_scale
+          REAL(q) :: s(n)
+
+          REAL(q), ALLOCATABLE :: a(:,:), w(:), gtil(:)
+          REAL(q), ALLOCATABLE :: smax(:), smin(:)
+          INTEGER :: m, k
+
+          m = MAX(1, MIN(mu, n))
+          ALLOCATE(a(n,n), w(n), gtil(n))
+          a = 0.5_q*(b + TRANSPOSE(b))
+          CALL dsyev_wrap('V', n, a, w)   ! a eigenvectors, w eigenvalues ascending
+          gtil = MATMUL(TRANSPOSE(a), g)
+
+          ALLOCATE(smax(m))
+          smax = solve_subspace(w(1:m), gtil(1:m), a_scale, .TRUE.)
+          IF (n > m) THEN
+            ALLOCATE(smin(n-m))
+            smin = solve_subspace(w(m+1:n), gtil(m+1:n), a_scale, .FALSE.)
+          END IF
+
+          s = 0._q
+          DO k=1,m
+            s = s + a(:,k) * smax(k)
+          END DO
+          IF (n > m) THEN
+            DO k=1,n-m
+              s = s + a(:,m+k) * smin(k)
+            END DO
+            DEALLOCATE(smin)
+          END IF
+
+          DEALLOCATE(a, w, gtil, smax)
+        END FUNCTION prfo_step_with_a
+
+
+        FUNCTION solve_subspace(lam, g, a_scale, pick_max) RESULT(s)
+          REAL(q), INTENT(IN) :: lam(:), g(:), a_scale
+          LOGICAL, INTENT(IN) :: pick_max
+          REAL(q) :: s(SIZE(g))
+
+          INTEGER :: k, naug, idx
+          REAL(q), ALLOCATABLE :: aug(:,:), w(:)
+          REAL(q) :: denom
+
+          k = SIZE(g)
+          IF (k == 0) THEN
+            s = 0._q
+            RETURN
+          END IF
+
+          naug = k + 1
+          ALLOCATE(aug(naug,naug), w(naug))
+          aug = 0._q
+          DO idx=1,k
+            aug(idx,idx) = (a_scale*a_scale) * lam(idx)
+            aug(idx,naug) = a_scale * g(idx)
+            aug(naug,idx) = a_scale * g(idx)
+          END DO
+          CALL dsyev_wrap('V', naug, aug, w)   ! aug becomes eigenvectors
+          IF (pick_max) THEN
+            idx = naug
+          ELSE
+            idx = 1
+          END IF
+
+          denom = aug(naug, idx)
+          IF (ABS(denom) < 1E-12_q) denom = SIGN(1E-12_q, denom + 1E-12_q)
+          s = (a_scale * aug(1:k, idx)) / denom
+
+          DEALLOCATE(aug, w)
+        END FUNCTION solve_subspace
+
+
+        FUNCTION solve_cone_step_alm(n, g, b, e, delta, cos_phi) RESULT(s)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: g(n), b(n,n), e(n), delta, cos_phi
+          REAL(q) :: s(n)
+
+          REAL(q) :: lam, mu, sigma, eta_t, eps_t, grad_norm, nu
+          REAL(q), PARAMETER :: sigma0 = 1._q, rho = 10._q, alpha = 0.5_q, beta = 1._q
+          REAL(q), PARAMETER :: eps = 1E-6_q, eta = 1E-6_q
+          INTEGER, PARAMETER :: max_outer = 50, max_inner = 200, ls_max = 20
+          REAL(q), PARAMETER :: step_size = 0.5_q, ls_decay = 0.5_q
+          INTEGER :: it
+
+          s = delta * e
+          lam = 0._q
+          mu = 0._q
+          sigma = sigma0
+          eta_t = sigma**(-1._q)
+          eps_t = sigma**(-alpha)
+
+          DO it=1,max_outer
+            CALL minimize_alm(n, s, g, b, e, delta, cos_phi, lam, mu, sigma, MAX(eta_t, CCQN_EPSR), max_inner, step_size, ls_decay, ls_max, grad_norm)
+            CALL cone_violation(n, s, e, delta, cos_phi, CCQN_EPSR, nu, mu, sigma)
+            IF (nu <= eps_t) THEN
+              IF (nu <= eps .AND. grad_norm <= eta) EXIT
+              CALL cone_update_multipliers(n, s, e, delta, cos_phi, CCQN_EPSR, lam, mu, sigma)
+              eta_t = MAX(eta_t/sigma, eta)
+              eps_t = MAX(eps_t/(sigma**beta), eps)
+            ELSE
+              sigma = MIN(1E6_q, sigma*rho)
+              eta_t = MAX(eta_t/sigma, eta)
+              eps_t = MAX(eps_t/(sigma**alpha), eps)
+            END IF
+          END DO
+
+          CALL cone_project(n, s, e, delta, cos_phi, CCQN_EPSR)
+        END FUNCTION solve_cone_step_alm
+
+
+        SUBROUTINE minimize_alm(n, s, g, b, e, delta, cos_phi, lam, mu, sigma, grad_tol, max_inner, step_size, ls_decay, ls_max, grad_norm)
+          INTEGER, INTENT(IN) :: n, max_inner, ls_max
+          REAL(q), INTENT(INOUT) :: s(n)
+          REAL(q), INTENT(IN) :: g(n), b(n,n), e(n), delta, cos_phi, lam, mu, sigma, grad_tol, step_size, ls_decay
+          REAL(q), INTENT(OUT) :: grad_norm
+
+          REAL(q), ALLOCATABLE :: grad(:), s_new(:)
+          REAL(q) :: lval, lnew, step
+          INTEGER :: it, ls
+
+          ALLOCATE(grad(n), s_new(n))
+          DO it=1,max_inner
+            CALL alm_value_grad(n, s, g, b, e, delta, cos_phi, lam, mu, sigma, CCQN_EPSR, lval, grad, grad_norm)
+            IF (grad_norm <= grad_tol) EXIT
+            step = step_size
+            DO ls=1,ls_max
+              s_new = s - step*grad
+              CALL alm_value_only(n, s_new, g, b, e, delta, cos_phi, lam, mu, sigma, CCQN_EPSR, lnew)
+              IF (lnew <= lval - 1E-4_q*step*(grad_norm**2)) THEN
+                s = s_new
+                EXIT
+              END IF
+              step = step*ls_decay
+            END DO
+            IF (ls > ls_max) s = s - step*grad
+          END DO
+          DEALLOCATE(grad, s_new)
+        END SUBROUTINE minimize_alm
+
+
+        SUBROUTINE alm_value_grad(n, s, g, b, e, delta, cos_phi, lam, mu, sigma, epsr, lval, grad, grad_norm)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: s(n), g(n), b(n,n), e(n), delta, cos_phi, lam, mu, sigma, epsr
+          REAL(q), INTENT(OUT) :: lval, grad(n), grad_norm
+
+          REAL(q), ALLOCATABLE :: bs(:), grad_ceq(:), grad_cin(:)
+          REAL(q) :: r, c_eq, c_ineq, t, fquad
+
+          ALLOCATE(bs(n), grad_ceq(n), grad_cin(n))
+          CALL cone_terms(n, s, e, delta, cos_phi, epsr, r, c_eq, c_ineq, grad_ceq, grad_cin)
+          bs = MATMUL(b, s)
+          fquad = SUM(g*s) + 0.5_q*SUM(s*bs)
+          t = MAX(mu/sigma + c_ineq, 0._q)
+          lval = fquad + lam*c_eq + 0.5_q*sigma*c_eq*c_eq + 0.5_q*sigma*(t*t - (mu/sigma)*(mu/sigma))
+          grad = g + bs + (lam + sigma*c_eq)*grad_ceq + sigma*t*grad_cin
+          grad_norm = SQRT(SUM(grad*grad))
+          DEALLOCATE(bs, grad_ceq, grad_cin)
+        END SUBROUTINE alm_value_grad
+
+
+        SUBROUTINE alm_value_only(n, s, g, b, e, delta, cos_phi, lam, mu, sigma, epsr, lval)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: s(n), g(n), b(n,n), e(n), delta, cos_phi, lam, mu, sigma, epsr
+          REAL(q), INTENT(OUT) :: lval
+
+          REAL(q), ALLOCATABLE :: bs(:), grad_ceq(:), grad_cin(:)
+          REAL(q) :: r, c_eq, c_ineq, t, fquad
+
+          ALLOCATE(bs(n), grad_ceq(n), grad_cin(n))
+          CALL cone_terms(n, s, e, delta, cos_phi, epsr, r, c_eq, c_ineq, grad_ceq, grad_cin)
+          bs = MATMUL(b, s)
+          fquad = SUM(g*s) + 0.5_q*SUM(s*bs)
+          t = MAX(mu/sigma + c_ineq, 0._q)
+          lval = fquad + lam*c_eq + 0.5_q*sigma*c_eq*c_eq + 0.5_q*sigma*(t*t - (mu/sigma)*(mu/sigma))
+          DEALLOCATE(bs, grad_ceq, grad_cin)
+        END SUBROUTINE alm_value_only
+
+
+        SUBROUTINE cone_terms(n, s, e, delta, cos_phi, epsr, r, c_eq, c_ineq, grad_ceq, grad_cin)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: s(n), e(n), delta, cos_phi, epsr
+          REAL(q), INTENT(OUT) :: r, c_eq, c_ineq, grad_ceq(n), grad_cin(n)
+
+          r = SQRT(SUM(s*s))
+          IF (r < epsr) r = epsr
+          c_eq = r - delta
+          c_ineq = r*cos_phi - SUM(e*s)
+          grad_ceq = s / r
+          grad_cin = cos_phi*s / r - e
+        END SUBROUTINE cone_terms
+
+
+        SUBROUTINE cone_project(n, s, e, delta, cos_phi, epsr)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(INOUT) :: s(n)
+          REAL(q), INTENT(IN) :: e(n), delta, cos_phi, epsr
+
+          REAL(q) :: r, dot, a_target, b_target, b
+          REAL(q), ALLOCATABLE :: perp(:)
+
+          IF (delta <= 0._q) THEN
+            s = 0._q
+            RETURN
+          END IF
+
+          r = SQRT(SUM(s*s))
+          IF (r < epsr) THEN
+            s = delta * e
+            RETURN
+          END IF
+          s = s * (delta / r)
+
+          dot = SUM(e*s)
+          a_target = delta * cos_phi
+          IF (dot >= a_target - 1E-12_q) RETURN
+
+          ALLOCATE(perp(n))
+          perp = s - dot*e
+          b = SQRT(SUM(perp*perp))
+
+          IF (b < epsr) THEN
+            perp = 0._q
+            perp(1) = 1._q
+            perp = perp - SUM(perp*e)*e
+            b = SQRT(SUM(perp*perp))
+            IF (b < epsr .AND. n >= 2) THEN
+              perp = 0._q
+              perp(2) = 1._q
+              perp = perp - SUM(perp*e)*e
+              b = SQRT(SUM(perp*perp))
+            END IF
+            IF (b < epsr .AND. n >= 3) THEN
+              perp = 0._q
+              perp(3) = 1._q
+              perp = perp - SUM(perp*e)*e
+              b = SQRT(SUM(perp*perp))
+            END IF
+          END IF
+
+          IF (b < epsr) THEN
+            perp = 0._q
+            perp(1) = 1._q
+            b = 1._q
+          END IF
+
+          b_target = SQRT(MAX(delta*delta - a_target*a_target, 0._q))
+          s = a_target*e + (b_target/b)*perp
+          DEALLOCATE(perp)
+        END SUBROUTINE cone_project
+
+
+        SUBROUTINE cone_violation(n, s, e, delta, cos_phi, epsr, nu, mu, sigma)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: s(n), e(n), delta, cos_phi, epsr, mu, sigma
+          REAL(q), INTENT(OUT) :: nu
+
+          REAL(q), ALLOCATABLE :: gce(:), gci(:)
+          REAL(q) :: r, c_eq, c_ineq, t
+
+          ALLOCATE(gce(n), gci(n))
+          CALL cone_terms(n, s, e, delta, cos_phi, epsr, r, c_eq, c_ineq, gce, gci)
+          IF (sigma > 0._q) THEN
+            t = MAX(c_ineq, -mu/sigma)
+          ELSE
+            t = MAX(c_ineq, 0._q)
+          END IF
+          nu = SQRT(c_eq*c_eq + t*t)
+          DEALLOCATE(gce, gci)
+        END SUBROUTINE cone_violation
+
+
+        SUBROUTINE cone_update_multipliers(n, s, e, delta, cos_phi, epsr, lam, mu, sigma)
+          INTEGER, INTENT(IN) :: n
+          REAL(q), INTENT(IN) :: s(n), e(n), delta, cos_phi, epsr, sigma
+          REAL(q), INTENT(INOUT) :: lam, mu
+
+          REAL(q), ALLOCATABLE :: gce(:), gci(:)
+          REAL(q) :: r, c_eq, c_ineq
+
+          ALLOCATE(gce(n), gci(n))
+          CALL cone_terms(n, s, e, delta, cos_phi, epsr, r, c_eq, c_ineq, gce, gci)
+          lam = lam + sigma*c_eq
+          mu = MAX(mu + sigma*c_ineq, 0._q)
+          DEALLOCATE(gce, gci)
+        END SUBROUTINE cone_update_multipliers
+
+!-----------------------------------------------------------------------
+! Local uppercase helper (avoids dependency on string module's uppercase,
+! which is absent in VASP 6.1.x)
+!-----------------------------------------------------------------------
+        PURE FUNCTION ccqn_uppercase(s) RESULT(res)
+          CHARACTER(LEN=*), INTENT(IN) :: s
+          CHARACTER(LEN=LEN(s)) :: res
+          INTEGER :: i, ic
+          res = s
+          DO i = 1, LEN_TRIM(s)
+            ic = IACHAR(s(i:i))
+            IF (ic >= IACHAR('a') .AND. ic <= IACHAR('z')) &
+     &        res(i:i) = ACHAR(ic - 32)
+          END DO
+        END FUNCTION ccqn_uppercase
+
+      END MODULE ccqn_ts
